# Variables compartidas a nivel del repo.
#
# Para el backend (Laravel) ver apps/api/.env.example
# Para el frontend (Next.js) ver apps/web/.env.local.example
#
# Hoy las imágenes se guardan en el disco local del backend (apps/api/storage/app/public).
# Si en el futuro se integra Cloudinary u otro storage externo, las variables
# correspondientes vivirán en apps/api/.env, no aquí.

NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Sentry (frontend) ────────────────────────────────────────────
# Si NEXT_PUBLIC_SENTRY_DSN está vacío, el SDK no se carga en cliente.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
