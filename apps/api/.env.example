APP_NAME=ClickToEat
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Mexico_City
APP_URL=http://localhost:8080
APP_LOCALE=es
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=clicktoeat
DB_USERNAME=clicktoeat
DB_PASSWORD=clicktoeat

BROADCAST_CONNECTION=log
CACHE_STORE=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# API token-only — dejar vacío para Next.js standalone.
# Sólo pon aquí dominios si tu frontend comparte cookie con la API.
SANCTUM_STATEFUL_DOMAINS=
SESSION_DOMAIN=

FRONTEND_URL=http://localhost:3000

# Public URL the QR/WhatsApp messages link back to (defaults to FRONTEND_URL)
PUBLIC_MENU_BASE_URL=

L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_CONST_HOST=http://localhost:8080/api/v1
