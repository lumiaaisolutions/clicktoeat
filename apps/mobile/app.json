{
  "expo": {
    "name": "ClickToEat",
    "slug": "clicktoeat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "clicktoeat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.lumia.clicktoeat",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "remote-notification"
        ],
        "NSCameraUsageDescription": "Para tomar fotos de productos y subirlas al catálogo.",
        "NSPhotoLibraryUsageDescription": "Para seleccionar imágenes de productos desde la galería."
      }
    },
    "android": {
      "package": "com.lumia.clicktoeat",
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAFAF7",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-audio"
    ],
    "extra": {
      "apiUrl": "https://clicktoeat-api.lumiaaisolutions.com/api/v1"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
